AUDITY_ENV=production
AUDITY_IMAGE_REGISTRY=ghcr.io/ozel0t-g
AUDITY_VERSION=latest
AUDITY_UPDATE_REPOSITORY=Ozel0t-G/Audity-Streamline-the-Audit-Process
AUDITY_UPDATE_BRANCH=production
AUDITY_UPDATE_CHANNEL=production
AUDITY_UPDATE_MANIFEST_PATH=audity/update-channel.json
AUDITY_UPDATE_CHECK_URL=
AUDITY_UPDATER_URL=http://audity-updater:3099
AUDITY_UPDATER_TOKEN=replace-with-secure-updater-token
AUDITY_HOST_PROJECT_DIR=/opt/audity
AUDITY_PUBLIC_URL=https://audity.example.com
AUDITY_WEB_PORT=80
AUDITY_API_PORT=3000
AUDITY_MINIO_API_PORT=9000
AUDITY_MINIO_CONSOLE_PORT=9001
AUDITY_APP_SECRET=replace-with-secure-random-secret
AUDITY_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
AUDITY_POSTGRES_DB=audity
AUDITY_POSTGRES_USER=audity
AUDITY_POSTGRES_PASSWORD=replace-with-secure-database-password
AUDITY_DATABASE_URL=postgres://audity:replace-with-secure-database-password@audity-db:5432/audity
AUDITY_REDIS_URL=redis://audity-redis:6379
AUDITY_STORAGE_PROVIDER=minio
AUDITY_STORAGE_ENDPOINT=http://audity-storage:9000
AUDITY_STORAGE_PUBLIC_ENDPOINT=https://audity.example.com:9000
AUDITY_STORAGE_BUCKET=audity-evidence
AUDITY_BACKUP_BUCKET=audity-backups
AUDITY_STORAGE_ACCESS_KEY=replace-me
AUDITY_STORAGE_SECRET_KEY=replace-me
AUDITY_FRAMEWORK_YAML_DIR=frameworks
AUDITY_FRAMEWORK_YAML_SYNC_INTERVAL_SECONDS=10
AUDITY_DEFAULT_FRAMEWORK_KEY=nist-csf-2
AUDITY_DEFAULT_FRAMEWORK_ID=
AUDITY_REQUIRE_MFA=false
AUDITY_PUBLIC_REGISTRATION=false
AUDITY_SEED_ADMIN_EMAIL=admin@audity.local
AUDITY_SEED_ADMIN_PASSWORD=replace-with-secure-initial-admin-password
AUDITY_SMTP_ENABLED=false
AUDITY_SMTP_HOST=smtp.example.com
AUDITY_SMTP_PORT=587
AUDITY_SMTP_TLS=true
AUDITY_SMTP_USER=replace-me
AUDITY_SMTP_PASSWORD=replace-me
AUDITY_LOG_LEVEL=info
AUDITY_SESSION_IDLE_TIMEOUT_MINUTES=30
